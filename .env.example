# MongoDB Configuration
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=admin123
MONGO_DATABASE=app-env-manager
MONGO_PORT=27017

# Backend Configuration
BACKEND_PORT=8080
# For local development use: mongodb://localhost:27017
# For Docker use: mongodb://admin:admin123@mongodb:27017/app-env-manager?authSource=admin
MONGODB_URI=mongodb://admin:admin123@mongodb:27017/app-env-manager?authSource=admin
MONGODB_DATABASE=app-env-manager

# Security Configuration
# IMPORTANT: Generate strong secrets before deployment.
# JWT secret:         openssl rand -hex 32
# Encryption key:     openssl rand -hex 16   (must be exactly 32 bytes)
JWT_SECRET=CHANGE_ME_USE_openssl_rand_hex_32
JWT_EXPIRY=24h
SSH_KEY_ENCRYPTION_KEY=CHANGE_ME_32BYTES_USE_openssl_rand

# Frontend Configuration
FRONTEND_PORT=80
FRONTEND_HTTPS_PORT=443
ALLOWED_ORIGINS=http://localhost,https://localhost
VITE_API_URL=https://localhost/api
VITE_WS_URL=wss://localhost/ws

# Default Admin User
# The admin password is auto-generated on first startup and printed to the
# container logs. No ADMIN_PASSWORD value is used in code.

# Application Settings
LOG_LEVEL=info
SESSION_TIMEOUT=24h

# Health Check Settings
HEALTH_CHECK_INTERVAL=60s
HEALTH_CHECK_TIMEOUT=10s

# SSH Settings
SSH_CONNECTION_TIMEOUT=30s
SSH_COMMAND_TIMEOUT=300s

# WebSocket Settings
WS_READ_BUFFER_SIZE=1024
WS_WRITE_BUFFER_SIZE=1024

# MongoDB Express (Optional - for debugging)
ME_USERNAME=admin
ME_PASSWORD=admin123
ME_PORT=8081
