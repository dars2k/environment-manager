# MongoDB Configuration
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=admin123
MONGO_DATABASE=app-env-manager
MONGO_PORT=27017

# Backend Configuration
BACKEND_PORT=8080
MONGODB_URI=mongodb://admin:admin123@mongodb:27017/app-env-manager?authSource=admin
MONGODB_DATABASE=app-env-manager

# Security Configuration
# IMPORTANT: Replace these values with strong, randomly-generated secrets before deployment.
# Generate a JWT secret: openssl rand -hex 32
# Generate an encryption key: openssl rand -hex 16  (must be exactly 32 bytes)
JWT_SECRET=203c7480772f762974e78e6a2a36dd7728c2c1f0bd8248f7a051f691dc720a76
SSH_KEY_ENCRYPTION_KEY=b8536dd217d95787bb51602dc807b9ac

# Frontend Configuration
FRONTEND_PORT=80
# Include both https and http so the WebSocket origin check passes whether
# the browser connects via HTTP (redirected) or directly over HTTPS.
ALLOWED_ORIGINS=https://localhost,http://localhost
# Trusted hostnames exempt from SSRF checks (Docker container names for test environments)
ALLOWED_HOSTS=test-environment-1,test-environment-2

# Other settings
LOG_LEVEL=debug
